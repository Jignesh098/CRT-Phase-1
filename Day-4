//Problem-1 
//Print 1-10, 10 times using nested loop

#include <iostream>
using namespace std;
int main()
{
    //number of times to print pattern
    for(int i = 1; i <=10; i++){
        //this defines what to print inside pattern
        for(int j = 1; j <=10; j++){
            cout << j << " ";
        }
        cout << "\n";
    }

    return 0;
}

