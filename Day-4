using namespace std;
int main()
{
    int n;
    cin >> n;
    for(int i = 1; i <= n; i++){
        for(int j = 1; j <= i; j++){
            cout << "*";
        }
        cout << "\n";
    }

    return 0;
}



//Problem-4
//Print mirror image of right angle triangle using pattern

#include <iostream>
using namespace std;
int main()
{
    int n;
    cin >> n;
    for(int i = 1; i <= n; i++){
        for(int j = n-i; j>=1; j--){
            cout << " ";
        }
        for(int k=1; k<=i; k++){
            cout << "*";
        }
        cout << "\n";
    }

    return 0;
}



