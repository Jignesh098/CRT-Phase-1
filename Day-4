//Problem-6
//Print Hollow square using pattern

#include <iostream>
using namespace std;
int main()
{
    int n;
    cin >> n;
    
    for(int i = 1; i <= n; i++){
        for(int j = 1; j<=n; j++){
            cout << " ";
            if((i==1)||(j==1)||(i==n)||(j==n)){
                cout << "*";
            } else {
                cout << " ";
            }
        }
        cout << "\n";
    }

    return 0;
}


