//Problem 8
//Fibonacci Series

#include <iostream>
using namespace std;

int main()
{
    int n;
    cin >> n;
    int c;
    
    int a = 0;
    int b = 1;
    
    for(int i = 0; i <= n; i++){
        cout << a << " ";
        c = a + b;
        a = b;
        b = c;
    }
    return 0;
}

